{
  "name": "virteex-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/virteex-api/virteex-api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/virteex-api",
        "main": "apps/virteex-api/virteex-api/src/main.ts",
        "tsConfig": "apps/virteex-api/virteex-api/tsconfig.app.json",
        "assets": ["apps/virteex-api/virteex-api/src/assets"],
        "webpackConfig": "apps/virteex-api/virteex-api/webpack.config.js"
      },
      "configurations": {
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "inspect": false
        },
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/virteex-api/virteex-api/src/environments/environment.ts",
              "with": "apps/virteex-api/virteex-api/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "virteex-api:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "virteex-api:build:development"
        },
        "production": {
          "buildTarget": "virteex-api:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/virteex-api/virteex-api/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
